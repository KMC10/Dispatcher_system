@model IEnumerable<DHLManagementSystem.Models.Driver>

@{
    ViewData["Title"] = "Drivers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">Drivers</h2>
        <small class="text-muted">Manage driver records and availability</small>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        + Add Driver
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">

        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Full Name</th>
                    <th>License Number</th>
                    <th>Phone</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.FullName</td>
                        <td>@item.LicenseNumber</td>
                        <td>@item.PhoneNumber</td>

                        <td>
                            @if (item.IsAvailable)
                            {
                                <span class="badge bg-success-subtle text-success">
                                    Available
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary">
                                    Busy
                                </span>
                            }
                        </td>

                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">
                                Edit
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1">
                                View
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                Remove
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>