@{
    ViewData["Title"] = "Dashboard";
}

@if (TempData["RecommendationMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["RecommendationMessage"]
    </div>
}

<div class="mb-4">
    <h2 class="mb-0">Operations Dashboard</h2>
    <small class="text-muted">Real-time overview of transport and fleet activity</small>
</div>

<!-- KPI ROW -->
<div class="row g-4 mb-4">

    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <small class="text-muted">Fleet Status</small>
                <h3 class="fw-semibold mt-2">Vehicles</h3>
                <div class="text-muted">View availability & maintenance</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <small class="text-muted">Driver Readiness</small>
                <h3 class="fw-semibold mt-2">Drivers</h3>
                <div class="text-muted">Manage personnel allocation</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <small class="text-muted">Scheduled Trips</small>
                <h3 class="fw-semibold mt-2">Trips</h3>
                <div class="text-muted">Departures & capacity</div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <small class="text-muted">Shipment Workflow</small>
                <h3 class="fw-semibold mt-2">Shipments</h3>
                <div class="text-muted">Pending & assigned deliveries</div>
            </div>
        </div>
    </div>

</div>

<!-- SECOND ROW -->
<div class="row g-4">

    <!-- Activity Panel -->
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6 class="mb-3">Operational Summary</h6>

                <div class="border rounded p-3 mb-3 bg-light">
                    Fleet operating within normal parameters.
                </div>

                <div class="border rounded p-3 mb-3 bg-light">
                    No critical maintenance alerts.
                </div>

                @if (ViewBag.PendingShipments != null && ViewBag.PendingShipments.Count > 0)
                {
                    <div class="border rounded p-3 bg-warning-subtle">
                        <strong>Pending Shipment Recommendations:</strong>

                        <ul class="mt-2 mb-0">
                            @foreach (var shipment in ViewBag.PendingShipments)
                            {
                                <li class="mb-1">
                                    <strong>@shipment.Origin</strong> → <strong>@shipment.Destination</strong>
                                    (Deadline: @shipment.DeliveryDeadline.ToString("dd MMM"))

                                    <a asp-controller="Shipments" asp-action="Recommend" asp-route-id="@shipment.Id"
                                           class="ms-2">
                                        Recommend Trip
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }
                else
                {
                    <div class="border rounded p-3 bg-light">
                        No pending shipment recommendations.
                    </div>
                }

            </div>
        </div>
    </div>

    <!-- System Status -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h6 class="mb-3">System Status</h6>

                <div class="d-flex justify-content-between mb-2">
                    <span>Database</span>
                    <span class="badge bg-success-subtle text-success">Online</span>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span>Dispatch Module</span>
                    <span class="badge bg-success-subtle text-success">Active</span>
                </div>

                <div class="d-flex justify-content-between">
                    <span>Recommendation Engine</span>

                    @if (ViewBag.RecommendationStatus == "Active")
                    {
                        <span class="badge bg-warning text-dark">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-success-subtle text-success">Idle</span>
                    }
                </div>

            </div>
        </div>
    </div>

</div>