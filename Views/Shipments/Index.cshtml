@model IEnumerable<DHLManagementSystem.Models.Shipment>

@{
    ViewData["Title"] = "Shipments";

    var pending = Model.Where(s => (s.Status ?? "").ToLower().Contains("pending"));
    var assigned = Model.Where(s => (s.Status ?? "").ToLower().Contains("assigned"));
    var inTransit = Model.Where(s => (s.Status ?? "").ToLower().Contains("transit"));
    var delivered = Model.Where(s => (s.Status ?? "").ToLower().Contains("delivered"));
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">Shipment Workflow</h2>
        <small class="text-muted">Manage routing, scheduling and delivery progression</small>
    </div>

    <div>
        @* <button class="btn btn-outline-dark me-2" onclick="showKanban()">Kanban View</button> *@
        <button class="btn btn-dark" onclick="showTable()">Table View</button>
        <a asp-action="Create" class="btn btn-secondary ms-3">
            + New Shipment
        </a>
    </div>
</div>

